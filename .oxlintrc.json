{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "unicorn", "typescript", "oxc", "nextjs", "jsx-a11y", "import", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "settings": {
    "next": {
      "rootDir": "app"
    }
  },
  "rules": {
    "no-unused-vars": "warn",
    "react/react-in-jsx-scope": "off",
    "import/no-named-as-default": "off",
    "import/no-unassigned-import": ["error", { "allow": ["**/*.css", "@testing-library/**"] }]
  },
  "ignorePatterns": ["node_modules", ".next", "out", "coverage", "next-env.d.ts"]
}
